{
  "name": "aetherglyph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Aetherglyph: Arcane Duels — Android-first, draw-to-cast 1v1 wizard duel. Phase 3 adds an authoritative online duel service (Express + Socket.IO) on top of the deterministic shared simulation. Vanilla ES modules + Three.js, no build step.",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "serve": "node server.js",
    "gen:spells": "node scripts/generate-spells.js",
    "vendor:three": "node scripts/copy-three.js",
    "vendor:socketio": "node scripts/copy-socketio.js",
    "gesture:audit": "node scripts/gesture-audit.js",
    "test": "node test/run.js",
    "test:server": "node test/server.test.js",
    "test:browser": "node test/browser/smoke.mjs",
    "postinstall": "node scripts/copy-three.js && node scripts/copy-socketio.js",
    "prepare:assets": "node scripts/generate-spells.js && node scripts/copy-three.js && node scripts/copy-socketio.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.8.3",
    "three": "^0.160.1"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "puppeteer-core": "^25.3.0",
    "socket.io-client": "^4.8.3"
  },
  "optionalDependencies": {
    "pg": "^8.22.0"
  }
}
