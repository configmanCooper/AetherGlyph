# Dependencies
node_modules/

# Vendored copies produced by scripts/copy-*.js (regenerated on install)
client/vendor/three.module.js
client/vendor/socket.io.esm.min.js

# Logs / OS / editor cruft
*.log
npm-debug.log*
.DS_Store
Thumbs.db
.idea/
.vscode/

# Runtime / build output (Phase 2+)
dist/
coverage/

# Capacitor web staging (regenerated by scripts/stage-web.js)
www/

# Android: the Capacitor project IS committed, but build output, local signing
# material, and the Capacitor-copied web assets are NOT. (android/.gitignore also
# applies; keystore lines there are commented out, so guard secrets here.)
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/keystore.properties
android/*.keystore
android/*.jks
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json
build-tools/
